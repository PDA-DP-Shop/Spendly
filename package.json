{
  "name": "spendly-monorepo",
  "private": true,
  "workspaces": [
    "apps/spendly-user",
    "apps/spendly-shop"
  ],
  "scripts": {
    "dev:user": "cd apps/spendly-user && npm run dev",
    "dev:shop": "cd apps/spendly-shop && npm run dev",
    "build:user": "cd apps/spendly-user && npm run build",
    "build:shop": "cd apps/spendly-shop && npm run build"
  }
}
